{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "16000"
  },
  "permissions": {
    "allow": [
      "Bash(git -C /home/eug/dev/projects/my/phrasal remote -v)",
      "Read(//home/eug/dev/projects/my/phrasal/.github/workflows/**)",
      "Bash(node -e \"import\\('/home/eug/dev/projects/my/phrasal/src/data/phrasalVerbs.js'\\).then\\(m => console.log\\('total:', m.rawData.length, 'active:', m.allVerbs.length\\)\\)\")",
      "Bash(backlog task *)",
      "mcp__backlog__task_search",
      "mcp__backlog__task_create",
      "mcp__backlog__task_complete",
      "mcp__backlog__task_edit",
      "mcp__backlog__get_backlog_instructions",
      "mcp__backlog__task_view",
      "mcp__backlog__*_*",
      "mcp__backlog__*",
      "Bash(node -e \"import\\('/home/eug/dev/projects/my/phrasal/src/data/phrasalVerbs.js'\\).then\\(m => console.log\\(m.rawData.length\\)\\)\")",
      "Bash(npx vitest *)",
      "Bash(node -e ' *)",
      "Bash(npx tsc *)",
      "Bash(git tag *)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-blackbox-log.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/prompt-audit-log.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/save-plan.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "jq -r '\"\\u001b[1;36m\\(.model.display_name) \u001b[0;36m[effort: \\(.effort.level) | think: \\(.thinking.enabled)]\\u001b[0m | context: \\u001b[33m\\(.context_window.used_percentage // 0)%\\u001b[0m | limit: \\u001b[32m\\(.rate_limits.five_hour.used_percentage)% [\\(.rate_limits.five_hour.resets_at | strflocaltime(\"%H:%M\"))]\\u001b[0m\"'"
  }
}
