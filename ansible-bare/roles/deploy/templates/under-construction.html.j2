<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Phrasal — Under Construction</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64' fill='none'%3E%3Crect x='4' y='4' width='56' height='44' rx='10' fill='%233b82f6'/%3E%3Cpath d='M14 48 L8 60 L26 52' fill='%233b82f6'/%3E%3Ctext x='32' y='33' font-family='Georgia,serif' font-size='30' font-weight='bold' text-anchor='middle' fill='white' letter-spacing='-1'%3EPh%3C/text%3E%3C/svg%3E">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      background-color: #f9fafb;
      color: #111827;
      transition: background-color 0.3s, color 0.3s;
    }

    @media (prefers-color-scheme: dark) {
      body { background-color: #030712; color: #f3f4f6; }
      .card { background-color: #111827; border-color: #1f2937; }
      .subtitle { color: #9ca3af; }
      .divider { border-color: #1f2937; }
      .footer-text { color: #6b7280; }
    }

    .card {
      max-width: 28rem;
      width: 100%;
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 1rem;
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1);
      padding: 2.5rem 2rem;
      text-align: center;
    }

    .logo {
      width: 4rem;
      height: 4rem;
      margin: 0 auto 1.5rem;
    }

    .title {
      font-size: 1.875rem;
      font-weight: 800;
      letter-spacing: -0.025em;
      margin-bottom: 0.5rem;
    }

    .accent { color: #3b82f6; }

    .subtitle {
      font-size: 1rem;
      color: #6b7280;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .status-bar {
      height: 0.5rem;
      border-radius: 9999px;
      background: linear-gradient(90deg, #3b82f6 60%, #e5e7eb 60%);
      margin-bottom: 1.5rem;
    }

    @media (prefers-color-scheme: dark) {
      .status-bar { background: linear-gradient(90deg, #3b82f6 60%, #374151 60%); }
    }

    .status-label {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #3b82f6;
      background: rgba(59, 130, 246, 0.1);
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      margin-bottom: 1.5rem;
    }

    .divider {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin-bottom: 1rem;
    }

    .footer-text {
      font-size: 0.875rem;
      color: #9ca3af;
    }

    .domain { font-weight: 600; color: #3b82f6; text-decoration: none; }
    .domain:hover { text-decoration: underline; }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .card { animation: fadeIn 0.4s ease-in-out; }
  </style>
</head>
<body>
  <div class="card">
    <svg class="logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
      <rect x="4" y="4" width="56" height="44" rx="10" fill="#3b82f6"/>
      <path d="M14 48 L8 60 L26 52" fill="#3b82f6"/>
      <text x="32" y="33" font-family="Georgia, serif" font-size="30" font-weight="bold"
            text-anchor="middle" fill="white" letter-spacing="-1">Ph</text>
    </svg>
    <h1 class="title"><span class="accent">Phrasal</span></h1>
    <p class="subtitle">We're building something new.<br>This site is currently under construction.</p>
    <span class="status-label">In Progress</span>
    <hr class="divider">
    <p class="footer-text">Visit us at <a class="domain" href="https://{{ domain }}">{{ domain }}</a></p>
  </div>
</body>
</html>
